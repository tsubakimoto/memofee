<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title><%= title || '2ペインレイアウト' %></title>
  <style>
    body {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    .global-header {
      width: 100vw;
      height: 56px;
      background: #222;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 32px;
      box-sizing: border-box;
    }
    .logo-area {
      display: flex;
      align-items: center;
      height: 100%;
    }
    .logo-img {
      height: 36px;
      width: auto;
      margin-right: 16px;
    }
    .global-menu {
      display: flex;
      align-items: center;
      gap: 24px;
    }
    .global-menu a {
      color: #fff;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 500;
      padding: 4px 12px;
      border-radius: 4px;
      transition: background 0.2s;
    }
    .global-menu a:hover {
      background: #444;
    }
    .container {
      display: flex;
      width: 100vw;
      height: 100vh;
    }
    .left-margin {
      width: 10%;
      background: #f5f5f5;
    }
    .left-pane {
      width: 20%;
      background: #e0e0e0;
    }
    .right-pane {
      width: 60%;
      background: #ffffff;
    }
    .right-margin {
      width: 10%;
      background: #f5f5f5;
    }
  </style>
</head>
<body>
  <header class="global-header">
    <div class="logo-area">
      <img src="/logo.png" alt="Logo" class="logo-img" />
    </div>
    <nav class="global-menu">
      <a href="/">ホーム</a>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/logout">ログアウト</a>
      <% } else { %>
        <a href="/login">ログイン</a>
      <% } %>
    </nav>
  </header>
  <div class="container">
    <div class="left-margin"></div>
    <div class="left-pane">
      <%- typeof left !== 'undefined' ? left : '' %>
    </div>
    <div class="right-pane">
      <%- typeof right !== 'undefined' ? right : '' %>
    </div>
    <div class="right-margin"></div>
  </div>
</body>
</html>
